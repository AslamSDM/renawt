# Authentication (NextAuth.js v5)
AUTH_SECRET=your-secret-key-here-min-32-chars-long-for-jwt
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/remawt?schema=public"

# R2 Storage (for screenshots and recordings)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=remawt-screenshots
R2_PUBLIC_URL=https://pub-your-account.r2.dev

# OpenRouter API (REQUIRED for AI models)
# Get your API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key

# Optional: Use Gemini instead of OpenRouter
# Set USE_GEMINI=true to use Google AI Studio (requires GOOGLE_AI_API_KEY)
# USE_GEMINI=true
# GOOGLE_AI_API_KEY=your-google-ai-studio-api-key

# Optional: Cloudflare Workers AI (Kimi K2.6 + Aura TTS + Flux image)
# CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
# CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
# CLOUDFLARE_AI_MODEL=@cf/moonshotai/kimi-k2.6
# CLOUDFLARE_TTS_MODEL=@cf/deepgram/aura-2-en
# CLOUDFLARE_IMAGE_MODEL=@cf/black-forest-labs/flux-1-schnell
# Set PREFER_CLOUDFLARE_TTS=false to keep ElevenLabs as primary
# PREFER_CLOUDFLARE_TTS=true
# CLOUDFLARE_REASONING_EFFORT=low   # low|medium|high — Kimi reasoning budget

# Remotion Lambda (frame-parallel render). Set RENDER_PROVIDER=lambda + creds.
# RENDER_PROVIDER=lambda
# REMOTION_LAMBDA_FUNCTION_NAME=remotion-render-4-0-416-mem2048mb-disk2048mb-300sec
# REMOTION_SERVE_URL=https://remotionlambda-<bucket>.s3.<region>.amazonaws.com/sites/<site>/index.html
# REMOTION_AWS_REGION=us-east-1
# REMOTION_AWS_ACCESS_KEY_ID=
# REMOTION_AWS_SECRET_ACCESS_KEY=
# REMOTION_FRAMES_PER_LAMBDA=20

# Analytics (PostHog)
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-project-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# VPS Generate Server
NEXT_PUBLIC_API_URL=http://your-vps-ip:3001

# API Key for signing VPS auth tokens (server-side only, must match VPS API_KEY)
API_KEY=your-shared-api-key

# Development: Disable credit checks
# DISABLE_CREDIT_CHECK=true
