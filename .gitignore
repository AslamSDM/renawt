# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─── dependencies ───────────────────────────────────────────
/node_modules
**/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── testing ────────────────────────────────────────────────
/coverage
**/coverage

# ─── next.js ────────────────────────────────────────────────
/.next/
**/.next/
/out/
**/out/

# ─── build output ───────────────────────────────────────────
/build
**/build/
/dist
**/dist/
generate-server/dist/
services/**/dist/
screenshot-api/dist/

# ─── misc / OS junk ─────────────────────────────────────────
.DS_Store
**/.DS_Store
*.pem
Thumbs.db

# ─── debug / logs ───────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
logs/
**/logs/
generate-server/logs/

# ─── env files ──────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── vercel ─────────────────────────────────────────────────
.vercel

# ─── typescript ─────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── prisma ─────────────────────────────────────────────────
prisma/dev.db
prisma/dev.db-journal
**/dev.db
**/dev.db-journal

# ─── remotion ───────────────────────────────────────────────
*.mp4
.remotion-temp/
**/.remotion-temp/
generate-server/.remotion-temp/

# ─── scratch / temp / cache ─────────────────────────────────
tmp/
**/tmp/
generate-server/tmp/
.cache/
**/.cache/
.ruff_cache
venv/
eg/

# ─── screenshots / renders (gitignored output) ──────────────
app/public/screenshots
generate-server/public/screenshots
public/screenshots
public/renders/*
!public/renders/.gitkeep
public/jitter/*
!public/jitter/.gitkeep

# ─── editor / IDE ───────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ─── playwright / test artifacts ────────────────────────────
.playwright-mcp/
playwright-report/
test-results/

# ─── claude / agent state ───────────────────────────────────
.claude/
.agent/

