# Server configuration
PORT=3001

# AI Model Provider
# Set to "true" to use Google AI Studio (Gemini)
USE_GEMINI=true

# Google AI API key (for Gemini)
GOOGLE_AI_API_KEY=your-google-ai-api-key

# Gemini model (optional, defaults to gemini-2.0-flash)
GEMINI_MODEL=gemini-3-pro-preview

# API Key for JWT auth (must match Vercel API_KEY)
API_KEY=your-shared-api-key

# Database (must be the SAME production DB as Vercel for credit checks)
DATABASE_URL=postgresql://user:password@your-db-host:5432/remawt?schema=public

# OpenRouter API key (alternative provider)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=moonshotai/kimi-k2.5
SITE_URL=http://localhost:3001

# Anthropic API key (for production)
ANTHROPIC_API_KEY=your-anthropic-api-key
