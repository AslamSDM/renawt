# Internal HTTP reverse-proxy.
# TLS is terminated upstream by Coolify's Traefik. This Caddy instance
# listens on plain HTTP inside the Docker network and path-routes to
# host-mode services (generate-server on :3001, render-service on :4002).
{
	auto_https off
	admin off
	log {
		output stdout
		format console
		level INFO
	}
	servers {
		timeouts {
			read_body 10m
			read_header 30s
			write 15m
			idle 15m
		}
	}
}

(cors_on_error) {
	# When the upstream fails (502/504/etc) Caddy returns its own response.
	# That response would otherwise lack CORS headers, so the browser
	# reports a CORS error instead of the real upstream failure. Echo the
	# origin back for any allowed value so failures surface as real errors.
	@allowed_origin header_regexp Origin "^https://(www\.)?remawt\.com$|^http://localhost:3000$"
	header @allowed_origin {
		Access-Control-Allow-Origin "{http.request.header.origin}"
		Access-Control-Allow-Credentials "true"
		Access-Control-Allow-Methods "GET,POST,PATCH,DELETE,OPTIONS"
		Access-Control-Allow-Headers "Content-Type,Authorization"
		Vary "Origin"
	}
}

(long_proxy) {
	transport http {
		dial_timeout 10s
		read_timeout 15m
		write_timeout 15m
		response_header_timeout 15m
	}
}

:80 {
	# Render-service handles all /render and /render/<id>/* paths.
	@render path /render /render/*
	handle @render {
		reverse_proxy render-service-render-service-1:4002 {
			import long_proxy
		}
	}

	# Everything else goes to generate-server (systemd on host).
	handle {
		reverse_proxy host.docker.internal:3001 {
			import long_proxy
		}
	}

	handle_errors {
		import cors_on_error
		respond "{err.status_code} {err.status_text}" {err.status_code}
	}
}
