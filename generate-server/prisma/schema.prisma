// This schema mirrors the root prisma/schema.prisma.
// It generates the Prisma client into generate-server/lib/generated/prisma
// so pnpm's strict hoisting doesn't block it.

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id          String   @id @default(cuid())
  userId      String?
  name        String?
  sourceUrl   String?
  description String?
  productData String?
  script      String?
  composition String?
  audioUrl    String?
  status      String   @default("DRAFT")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user       User?             @relation(fields: [userId], references: [id])
  recordings ScreenRecording[]
  images     ProductImage[]

  @@index([userId])
}

model ScreenRecording {
  id                String   @id @default(cuid())
  projectId         String
  videoUrl          String
  duration          Float
  cursorData        String
  trimStart         Float    @default(0)
  trimEnd           Float    @default(0)
  zoomPoints        String
  featureName       String
  description       String
  cursorStyle       String   @default("mac")
  processedVideoUrl String?
  processingStatus  String   @default("pending")
  createdAt         DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProductImage {
  id        String   @id @default(cuid())
  projectId String
  url       String
  name      String
  width     Int?
  height    Int?
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  name          String?
  image         String?
  emailVerified DateTime?
  creditBalance Int       @default(0)

  projects        Project[]
  subscription    Subscription?
  creditPurchases CreditPurchase[]
  accounts        Account[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Subscription {
  id        String @id @default(cuid())
  userId    String @unique
  plan      String
  status    String
  dodoSubId String

  user User @relation(fields: [userId], references: [id])
}

model CreditPurchase {
  id             String   @id @default(cuid())
  userId         String
  amount         Int
  dodoPurchaseId String
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model WebhookEvent {
  id String @id
}
