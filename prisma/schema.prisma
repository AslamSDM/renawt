generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id          String   @id @default(cuid())
  userId      String?
  name        String?
  sourceUrl   String?
  description String?
  productData String?
  script      String?
  composition String?
  jitterDoc   String?
  audioUrl    String?
  videoUrl    String?
  currentVersionId String?
  status      String   @default("DRAFT")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user            User?               @relation(fields: [userId], references: [id])
  recordings      ScreenRecording[]
  images          ProductImage[]
  jitterHistory   JitterDocHistory[]
  generations     Generation[]

  @@index([userId])
}

model Generation {
  id          String    @id @default(cuid())
  projectId   String
  userId      String?
  status      String    @default("RUNNING")
  videoUrl    String?
  params      String?
  doc         String?
  brandReport String?
  music       String?
  progress    String?
  error       String?
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([status])
}

model JitterDocHistory {
  id        String   @id @default(cuid())
  projectId String
  doc       String
  label     String?
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}

model ScreenRecording {
  id                String   @id @default(cuid())
  projectId         String
  videoUrl          String
  duration          Float
  cursorData        String // JSON: [{x, y, timestamp, type: "move"|"click"|"input"}]
  trimStart         Float    @default(0) // Trim in seconds
  trimEnd           Float    @default(0) // 0 = no trim (use full duration)
  zoomPoints        String // JSON: [{time, x, y, scale, duration}]
  featureName       String
  description       String
  cursorStyle       String   @default("mac") // mac, windows
  processedVideoUrl String? // URL of processed video (cursor replaced, zooms baked in)
  processingStatus  String   @default("pending") // pending | processing | complete | failed
  createdAt         DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProductImage {
  id        String   @id @default(cuid())
  projectId String
  url       String
  name      String
  width     Int?
  height    Int?
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  name          String?
  image         String?
  emailVerified DateTime?
  creditBalance Int       @default(0)

  projects        Project[]
  subscription    Subscription?
  creditPurchases CreditPurchase[]
  accounts        Account[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Subscription {
  id        String @id @default(cuid())
  userId    String @unique
  plan      String
  status    String
  dodoSubId String

  user User @relation(fields: [userId], references: [id])
}

model CreditPurchase {
  id             String   @id @default(cuid())
  userId         String
  amount         Int
  dodoPurchaseId String
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model WebhookEvent {
  id String @id
}

model Music {
  id         String   @id @default(cuid())
  title      String
  filename   String   @unique
  url        String
  artist     String?
  bpm        Int      @default(120)
  durationMs Int?
  moods      String[] @default([])
  source     String   @default("seed") // seed | pixabay | fma | jamendo | user
  license    String?  // e.g. "pixabay", "CC-BY", "CC0"
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([source])
  @@index([bpm])
}

model LlmCall {
  id               String   @id @default(cuid())
  provider         String
  model            String
  label            String
  inputTokens      Int      @default(0)
  outputTokens     Int      @default(0)
  totalTokens      Int      @default(0)
  latencyMs        Int      @default(0)
  ok               Boolean  @default(true)
  error            String?
  projectId        String?
  userId           String?
  createdAt        DateTime @default(now())

  @@index([projectId])
  @@index([userId])
  @@index([createdAt])
  @@map("llm_calls")
}
